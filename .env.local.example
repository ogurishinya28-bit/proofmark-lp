# =============================================================
# ProofMark - ローカル開発用 環境変数テンプレート
# =============================================================
# このファイルをコピーして .env.local を作成してください。
# .env.local は Git にコミットしないこと（.gitignore に追加済み）
#
# cp .env.local.example .env.local
# =============================================================

# -------------------------------------------------------------
# [PUBLIC] フロントエンド用 Supabase キー
# これらは VITE_ プレフィックスを持ち、ブラウザで参照されます。
# anon key は RLS によって保護されているため公開しても安全です。
# -------------------------------------------------------------
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.YOUR_ANON_KEY

# -------------------------------------------------------------
# [SECRET] サーバーサイド専用キー
# ⚠️ VITE_ プレフィックスを絶対に付けないこと。
# ⚠️ フロントエンドのコードで参照しないこと。
# ⚠️ このキーが漏洩すると RLS を完全にバイパスできるため危険。
#
# Vercel にデプロイ時は Vercel ダッシュボードの
# Settings > Environment Variables に設定してください。
# -------------------------------------------------------------
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.YOUR_SERVICE_ROLE_KEY

# -------------------------------------------------------------
# [SECRET] メール送信用 Resend API キー（既存設定）
# ⚠️ VITE_ プレフィックスを絶対に付けないこと。
# -------------------------------------------------------------
RESEND_API_KEY=re_YOUR_RESEND_API_KEY

# -------------------------------------------------------------
# [PUBLIC] Analytics（任意）
# -------------------------------------------------------------
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=
