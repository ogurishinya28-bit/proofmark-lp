{
  "version": 2,
  "public": true,
  "functions": {
    "api/og.ts": {
      "memory": 1024,
      "maxDuration": 10
    },
    "api/cert.ts": {
      "memory": 512
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/cert/:id",
      "destination": "/api/cert?id=:id"
    },
    {
      "source": "/u/:username",
      "destination": "/api/profile?username=:username"
    },
    {
      "source": "/((?!api/|cert/|u/|@|src/|node_modules/|client/|favicon.ico).*)",
      "destination": "/client/index.html"
    }
  ]
}