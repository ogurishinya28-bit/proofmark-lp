{
  "version": 2,
  "public": true,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/cert/:id",
      "destination": "/api/cert?id=:id"
    },
    {
      "source": "/u/:username",
      "destination": "/api/profile?username=:username"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}